<%- include('partials/head') %><%- include('partials/header') %><main class="container page"><div class="breadcrumbs"><a href="/">Beranda</a> / <a href="/kategori/<%= p.category %>">Kategori</a> / <%= p.name %></div><section class="product-detail"><div class="gallery"><div class="thumbs"><% (p.images||[]).forEach((im,i)=>{ %><button data-thumb="<%= im %>"><img src="<%= im %>" alt="Foto <%= i+1 %> <%= p.name %>"></button><% }) %></div><div class="main-photo"><img id="mainProductImage" src="<%= (p.images&&p.images[0])||'/assets/img/og-default.svg' %>" alt="<%= p.name %>"></div></div><div class="product-info"><span class="eyebrow"><%= p.marketplace %></span><h1><%= p.name %></h1><div class="rating">⭐ <%= p.rating %> · Terjual <%= p.soldLabel %></div><div class="price"><strong><%= money(p.price) %></strong><del><%= money(p.oldPrice) %></del></div><p><%= p.shortDescription %></p><div class="recommend"><h3>Kenapa kami merekomendasikan?</h3><ul><% p.advantages.forEach(x=>{ %><li>✓ <%= x %></li><% }) %></ul></div><a class="btn btn-buy" href="/go/<%= p.id %>" target="_blank" rel="nofollow sponsored noopener">Lihat di <%= p.marketplace %></a><button class="btn btn-white share-btn" data-title="<%= p.name %>">Bagikan</button></div></section><section class="content-card"><h2>Deskripsi Produk</h2><p><%= p.description %></p><h3>Kelebihan</h3><ul><% p.advantages.forEach(x=>{ %><li><%= x %></li><% }) %></ul><h3>Cocok Untuk</h3><div class="chips"><% p.suitableFor.forEach(x=>{ %><span><%= x %></span><% }) %></div><h3>Cara Penggunaan</h3><p><%= p.usage %></p></section><section class="section"><div class="section-head"><h2>Produk Serupa</h2></div><div class="product-grid"><% related.forEach(p=>{ %><%- include('partials/product-card',{p}) %><% }) %></div></section></main><%- include('partials/footer') %>