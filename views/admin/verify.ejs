<!doctype html><html lang="id"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Verifikasi 2FA</title><link rel="stylesheet" href="/assets/css/admin.css"></head><body class="auth-page"><form class="auth-card" method="post"><input type="hidden" name="_csrf" value="<%= csrf %>"><div class="admin-logo">2FA</div><h1>Verifikasi Keamanan</h1><p>Masukkan 6 digit kode dari aplikasi authenticator.</p><% if(flash.error?.length){ %><div class="alert danger"><%= flash.error[0] %></div><% } %><label>Kode 2FA<input name="token" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autofocus></label><button>Verifikasi</button></form></body></html>