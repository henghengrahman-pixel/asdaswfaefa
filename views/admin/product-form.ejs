<%- include('partials/top',{title:p?'Edit Produk':'Tambah Produk'}) %>
<form class="panel form-grid" method="post" action="/admin/products/save" enctype="multipart/form-data">
  <input type="hidden" name="_csrf" value="<%= csrf %>">
  <input type="hidden" name="id" value="<%= p?.id||'' %>">
  <label>Nama Produk<input name="name" value="<%= p?.name||'' %>" required></label>
  <label>Slug SEO<input name="slug" value="<%= p?.slug||'' %>" placeholder="otomatis dari nama"></label>
  <label>Kategori<select name="category"><% categories.forEach(c=>{ %><option value="<%= c.slug %>" <%= p?.category===c.slug?'selected':'' %>><%= c.name %></option><% }) %></select></label>
  <label>Marketplace<input name="marketplace" value="<%= p?.marketplace||'Shopee' %>"></label>
  <label>Harga<input name="price" type="number" min="0" value="<%= p?.price||'' %>" required></label>
  <label>Harga Lama<input name="oldPrice" type="number" min="0" value="<%= p?.oldPrice||'' %>"></label>
  <label class="full">Link Affiliate<input name="affiliateUrl" type="url" value="<%= p?.affiliateUrl||'' %>" placeholder="https://..." required></label>

  <% if(p?.images?.length){ %>
  <div class="full existing-images">
    <strong>Foto yang sudah tersimpan</strong>
    <p class="help">Centang foto yang ingin dihapus. Foto pertama menjadi foto utama produk.</p>
    <div class="image-admin-grid">
      <% p.images.forEach((im,i)=>{ %>
      <label class="image-admin-item">
        <img src="<%= im %>" alt="Foto <%= i+1 %> <%= p.name %>" onerror="this.src='/assets/img/og-default.svg'">
        <span><input type="checkbox" name="removeImages" value="<%= im %>"> Hapus foto <%= i+1 %></span>
        <% if(i===0){ %><b>Foto utama</b><% } %>
      </label>
      <% }) %>
    </div>
  </div>
  <% } %>

  <label class="full">Tambah Foto dari Link (maksimal 12 foto total)
    <textarea name="imageUrls" rows="6" placeholder="Satu link foto per baris&#10;https://domain.com/foto-1.jpg&#10;https://domain.com/foto-2.jpg"></textarea>
    <small class="help">Bisa masukkan beberapa link sekaligus. Setiap link harus diawali http:// atau https://.</small>
  </label>
  <label class="full">Atau Upload Foto (JPG, PNG, WEBP, GIF; maksimal 8 file, 5 MB/file)
    <input name="images" type="file" accept="image/jpeg,image/png,image/webp,image/gif" multiple>
  </label>

  <label class="full">Deskripsi Singkat<textarea name="shortDescription" required><%= p?.shortDescription||'' %></textarea></label>
  <label class="full">Deskripsi Produk<textarea name="description" rows="5" required><%= p?.description||'' %></textarea></label>
  <label>Kelebihan (1 baris per poin)<textarea name="advantages"><%= p?.advantages?.join('\n')||'' %></textarea></label>
  <label>Cocok Untuk (1 baris per poin)<textarea name="suitableFor"><%= p?.suitableFor?.join('\n')||'' %></textarea></label>
  <label class="full">Cara Penggunaan<textarea name="usage"><%= p?.usage||'' %></textarea></label>
  <label>Rating<input name="rating" type="number" step="0.1" min="1" max="5" value="<%= p?.rating||4.8 %>"></label>
  <label>Label Terjual<input name="soldLabel" value="<%= p?.soldLabel||'1RB+' %>"></label>
  <label class="check"><input type="checkbox" name="isFeatured" <%= p?.isFeatured?'checked':'' %>> Produk Viral</label>
  <label class="check"><input type="checkbox" name="isActive" <%= p?.isActive===false?'':'checked' %>> Aktif</label>
  <div class="full"><button class="primary">Simpan Produk</button></div>
</form>
<%- include('partials/bottom') %>
