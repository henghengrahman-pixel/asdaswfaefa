<%- include('partials/top',{title:p?'Edit Produk':'Tambah Produk'}) %><form class="panel form-grid" method="post" action="/admin/products/save" enctype="multipart/form-data"><input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="id" value="<%= p?.id||'' %>"><label>Nama Produk<input name="name" value="<%= p?.name||'' %>" required></label><label>Slug SEO<input name="slug" value="<%= p?.slug||'' %>" placeholder="otomatis dari nama"></label><label>Kategori<select name="category"><% categories.forEach(c=>{ %><option value="<%= c.slug %>" <%= p?.category===c.slug?'selected':'' %>><%= c.name %></option><% }) %></select></label><label>Marketplace<input name="marketplace" value="<%= p?.marketplace||'Shopee' %>"></label><label>Harga<input name="price" type="number" value="<%= p?.price||'' %>" required></label><label>Harga Lama<input name="oldPrice" type="number" value="<%= p?.oldPrice||'' %>"></label><label class="full">Link Affiliate<input name="affiliateUrl" type="url" value="<%= p?.affiliateUrl||'' %>" required></label><label class="full">Upload Foto (maks. 8)<input name="images" type="file" accept="image/*" multiple></label><label class="full">Atau URL Foto<input name="imageUrl" type="url" placeholder="https://..."></label><label class="full">Deskripsi Singkat<textarea name="shortDescription" required><%= p?.shortDescription||'' %></textarea></label><label class="full">Deskripsi Produk<textarea name="description" rows="5" required><%= p?.description||'' %></textarea></label><label>Kelebihan (1 baris per poin)<textarea name="advantages"><%= p?.advantages?.join('\n')||'' %></textarea></label><label>Cocok Untuk (1 baris per poin)<textarea name="suitableFor"><%= p?.suitableFor?.join('\n')||'' %></textarea></label><label class="full">Cara Penggunaan<textarea name="usage"><%= p?.usage||'' %></textarea></label><label>Rating<input name="rating" type="number" step="0.1" min="1" max="5" value="<%= p?.rating||4.8 %>"></label><label>Label Terjual<input name="soldLabel" value="<%= p?.soldLabel||'1RB+' %>"></label><label class="check"><input type="checkbox" name="isFeatured" <%= p?.isFeatured?'checked':'' %>> Produk Viral</label><label class="check"><input type="checkbox" name="isActive" <%= p?.isActive===false?'':'checked' %>> Aktif</label><div class="full"><button class="primary">Simpan Produk</button></div></form><%- include('partials/bottom') %>