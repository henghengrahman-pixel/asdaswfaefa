<%- include('partials/top',{title:'Artikel'}) %><div class="toolbar"><a class="primary" href="/admin/articles/new">+ Tambah Artikel</a></div><section class="panel table-wrap"><table><thead><tr><th>Judul</th><th>Kategori</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% articles.forEach(a=>{ %><tr><td><b><%= a.title %></b></td><td><%= a.category %></td><td><%= a.isPublished?'Terbit':'Draft' %></td><td><a href="/admin/articles/<%= a.id %>/edit">Edit</a> <form class="inline" method="post" action="/admin/articles/<%= a.id %>/delete"><input type="hidden" name="_csrf" value="<%= csrf %>"><button class="link danger-text">Hapus</button></form></td></tr><% }) %></tbody></table></section><%- include('partials/bottom') %>