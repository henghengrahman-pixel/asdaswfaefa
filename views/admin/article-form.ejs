<%- include('partials/top',{title:a?'Edit Artikel':'Tambah Artikel'}) %><form class="panel form-grid" method="post" action="/admin/articles/save" enctype="multipart/form-data"><input type="hidden" name="_csrf" value="<%= csrf %>"><input type="hidden" name="id" value="<%= a?.id||'' %>"><label class="full">Judul<input name="title" value="<%= a?.title||'' %>" required></label><label>Slug SEO<input name="slug" value="<%= a?.slug||'' %>"></label><label>Kategori<input name="category" value="<%= a?.category||'Tips Belanja' %>"></label><label class="full">Ringkasan<textarea name="excerpt" required><%= a?.excerpt||'' %></textarea></label><label>URL Cover<input name="cover" type="url" value="<%= a?.cover||'' %>"></label><label>Upload Cover<input name="coverFile" type="file" accept="image/*"></label><label class="full">Isi Artikel (HTML diperbolehkan)<textarea name="content" rows="14" required><%= a?.content||'' %></textarea></label><label>Tanggal Terbit<input name="publishedAt" type="datetime-local" value="<%= a?.publishedAt?new Date(a.publishedAt).toISOString().slice(0,16):'' %>"></label><label class="check"><input type="checkbox" name="isPublished" <%= a?.isPublished?'checked':'' %>> Terbitkan</label><div class="full"><button class="primary">Simpan Artikel</button></div></form><%- include('partials/bottom') %>