<%- include('partials/top',{title:'Produk'}) %><div class="toolbar"><a class="primary" href="/admin/products/new">+ Tambah Produk</a></div><section class="panel table-wrap"><table><thead><tr><th>Produk</th><th>Kategori</th><th>Harga</th><th>Klik</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% products.forEach(p=>{ %><tr><td><div class="product-cell"><img src="<%= p.images[0] %>"><b><%= p.name %></b></div></td><td><%= p.category %></td><td><%= money(p.price) %></td><td><%= p.clicks %></td><td><span class="status"><%= p.isActive?'Aktif':'Nonaktif' %></span></td><td><a href="/admin/products/<%= p.id %>/edit">Edit</a><form class="inline" method="post" action="/admin/products/<%= p.id %>/delete" onsubmit="return confirm('Hapus produk?')"><input type="hidden" name="_csrf" value="<%= csrf %>"><button class="link danger-text">Hapus</button></form></td></tr><% }) %></tbody></table></section><%- include('partials/bottom') %>