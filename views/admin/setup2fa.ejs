<!doctype html><html lang="id"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Aktifkan 2FA</title><link rel="stylesheet" href="/assets/css/admin.css"></head><body class="auth-page"><form class="auth-card wide" method="post"><input type="hidden" name="_csrf" value="<%= csrf %>"><h1>Aktifkan 2FA</h1><p>Scan QR dengan Google Authenticator/Authy, lalu masukkan kode 6 digit.</p><img class="qr" src="<%= qr %>" alt="QR 2FA"><code><%= secret %></code><% if(flash.error?.length){ %><div class="alert danger"><%= flash.error[0] %></div><% } %><label>Kode verifikasi<input name="token" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required></label><button>Aktifkan 2FA</button></form></body></html>