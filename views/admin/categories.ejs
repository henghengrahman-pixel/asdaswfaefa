<%- include('partials/top',{title:'Kategori'}) %><section class="panel"><form class="form-inline" method="post" action="/admin/categories/save"><input type="hidden" name="_csrf" value="<%= csrf %>"><input name="icon" placeholder="🛍️" style="max-width:80px"><input name="name" placeholder="Nama kategori" required><input name="slug" placeholder="slug-otomatis"><button class="primary">Tambah</button></form><div class="list"><% categories.forEach(c=>{ %><div class="row"><span><%= c.icon %> <b><%= c.name %></b> /<%= c.slug %></span><form method="post" action="/admin/categories/<%= c.id %>/delete"><input type="hidden" name="_csrf" value="<%= csrf %>"><button class="link danger-text">Hapus</button></form></div><% }) %></div></section><%- include('partials/bottom') %>