<%- include('partials/top',{title:'Dashboard'}) %><section class="stats"><div><small>Total Produk</small><strong><%= db.products.length %></strong></div><div><small>Total Klik</small><strong><%= db.clicks.length %></strong></div><div><small>Produk Viral</small><strong><%= db.products.filter(x=>x.isFeatured).length %></strong></div><div><small>Artikel</small><strong><%= db.articles.length %></strong></div></section><section class="panel"><h2>Klik 7 Hari Terakhir</h2><div class="bars"><% const max=Math.max(1,...last7.map(x=>x.count)); last7.forEach(x=>{ %><div><span style="height:<%= Math.max(4,(x.count/max)*180) %>px"></span><small><%= x.date.slice(5) %><br><b><%= x.count %></b></small></div><% }) %></div></section><div class="admin-grid"><section class="panel"><h2>Produk Terpopuler</h2><% [...db.products].sort((a,b)=>b.clicks-a.clicks).slice(0,6).forEach(p=>{ %><div class="row"><span><%= p.name %></span><b><%= p.clicks %> klik</b></div><% }) %></section><section class="panel"><h2>Aktivitas Terbaru</h2><% db.audit.slice(-8).reverse().forEach(a=>{ %><div class="row"><span><%= a.action %></span><small><%= new Date(a.at).toLocaleString('id-ID') %></small></div><% }) %></section></div><%- include('partials/bottom') %>