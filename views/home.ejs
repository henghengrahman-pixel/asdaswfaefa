<%- include('partials/head') %><%- include('partials/header') %><main><section class="hero"><div class="container hero-grid"><div><span class="eyebrow">REKOMENDASI PRODUK PILIHAN</span><h1>Temukan Produk Terbaik, <em>Harga Bersahabat</em></h1><p>Rekomendasi produk berguna, promo menarik, dan ulasan singkat agar belanja lebih mudah.</p><div class="actions"><a class="btn" href="#produk-viral">Lihat Produk Viral</a><a class="btn btn-white" href="#kategori">Kategori Produk</a></div></div><div class="hero-art"><div class="cart">🛒</div><div class="box b1">📦</div><div class="box b2">%</div></div></div></section><section class="trust"><div class="container trust-grid"><span>✓ Produk Pilihan</span><span>✓ Harga Bersahabat</span><span>✓ Mudah Diakses</span><span>✓ Informasi Jelas</span></div></section><section id="produk-viral" class="section container"><div class="section-head"><h2>🔥 Produk Viral</h2><a href="/cari">Lihat semua →</a></div><div class="product-grid"><% featured.forEach(p=>{ %><%- include('partials/product-card',{p}) %><% }) %></div></section><section id="kategori" class="section soft"><div class="container"><div class="section-head"><h2>Kategori Populer</h2></div><div class="category-grid"><% categories.forEach(c=>{ %><a href="/kategori/<%= c.slug %>"><span><%= c.icon %></span><b><%= c.name %></b></a><% }) %></div></div></section><section class="section container"><div class="section-head"><h2>Produk Terbaru</h2><a href="/cari">Lihat semua →</a></div><div class="product-grid"><% latest.forEach(p=>{ %><%- include('partials/product-card',{p}) %><% }) %></div></section><section class="section soft"><div class="container"><div class="section-head"><h2>Artikel & Tips Belanja</h2><a href="/artikel">Semua artikel →</a></div><div class="article-grid"><% articles.forEach(a=>{ %><a class="article-card" href="/artikel/<%= a.slug %>"><img src="<%= a.cover %>" alt="<%= a.title %>" loading="lazy"><div><small><%= a.category %></small><h3><%= a.title %></h3><p><%= a.excerpt %></p></div></a><% }) %></div></div></section></main><%- include('partials/footer') %>