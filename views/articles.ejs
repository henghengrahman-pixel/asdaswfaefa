<%- include('partials/head') %><%- include('partials/header') %><main class="container page"><h1>Artikel & Review</h1><div class="article-grid"><% articles.forEach(a=>{ %><a class="article-card" href="/artikel/<%= a.slug %>"><img src="<%= a.cover %>" alt="<%= a.title %>"><div><small><%= a.category %></small><h2><%= a.title %></h2><p><%= a.excerpt %></p></div></a><% }) %></div></main><%- include('partials/footer') %>