<article class="product-card"><a class="product-image" href="/produk/<%= p.slug %>"><% if(p.isFeatured){ %><span class="badge">Viral</span><% } %><img src="<%= p.images[0] %>" alt="<%= p.name %>" loading="lazy"></a><div class="product-body"><a class="product-title" href="/produk/<%= p.slug %>"><%= p.name %></a><strong><%= money(p.price) %></strong><div class="meta">⭐ <%= p.rating %> · Terjual <%= p.soldLabel %></div><a class="btn btn-soft" href="/produk/<%= p.slug %>">Lihat Produk</a></div></article>