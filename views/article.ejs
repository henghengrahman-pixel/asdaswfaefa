<%- include('partials/head') %><%- include('partials/header') %><main class="container page article-layout"><article class="article-main"><div class="breadcrumbs"><a href="/">Beranda</a> / <a href="/artikel">Artikel</a></div><h1><%= a.title %></h1><div class="meta"><%= a.category %> · <%= new Date(a.publishedAt).toLocaleDateString('id-ID') %></div><img class="cover" src="<%= a.cover %>" alt="<%= a.title %>"><div class="prose"><%- a.content %></div></article><aside><h3>Artikel Terbaru</h3><% latest.forEach(x=>{ %><a class="side-article" href="/artikel/<%= x.slug %>"><img src="<%= x.cover %>" alt=""><span><%= x.title %></span></a><% }) %></aside></main><%- include('partials/footer') %>