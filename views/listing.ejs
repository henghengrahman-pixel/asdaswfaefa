<%- include('partials/head') %><%- include('partials/header') %><main class="container page"><div class="breadcrumbs"><a href="/">Beranda</a> / <%= title %></div><div class="listing-head"><div><h1><%= title %></h1><p><%= products.length %> produk ditemukan</p></div></div><div class="chips"><a href="/cari">Semua</a><% categories.forEach(c=>{ %><a href="/kategori/<%= c.slug %>"><%= c.icon %> <%= c.name %></a><% }) %></div><div class="product-grid"><% products.forEach(p=>{ %><%- include('partials/product-card',{p}) %><% }) %></div><% if(!products.length){ %><div class="empty">Produk belum tersedia.</div><% } %></main><%- include('partials/footer') %>